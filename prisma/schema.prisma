generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- Enums ---
enum Gender {
  MALE
  FEMALE
  OTHER
  PREFER_NOT_TO_SAY
}

enum Language {
  ENGLISH
  TURKISH
  PERSIAN
}

enum TodoPriority {
  LOW
  MEDIUM
  HIGH
}

enum TodoCategory {
  STUDY
  ASSIGNMENT
  EXAM
  WORK
  GYM
  OTHER
}

enum TodoStatus {
  PENDING
  COMPLETED
  MISSED
}

enum AiInteractionContentType {
  USER_INPUT_MESSAGE
  MODEL_RESPONSE_MESSAGE
  FUNCTION_CALL_REQUEST
  FUNCTION_CALL_RESULT
}

enum MessageRating {
  UPVOTE
  DOWNVOTE
}

// --- Models ---
model User {
  id       String @id @default(cuid())
  name     String
  email    String @unique
  password String

  notificationsEnabled Boolean @default(false)

  profile             UserProfile?
  todos               Todo[]
  calendarEvents      CalendarEvent[]
  aiInteractionEvents AiInteractionEvent[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model UserProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  birthday DateTime?
  gender   Gender?
  language Language?

  school              String?
  degree              String?
  fieldOfStudy        String?
  educationStartDate  DateTime?
  isFinished          Boolean?  @default(false)
  finishDate          DateTime?
  estimatedFinishDate DateTime?
  gpa                 Float?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Todo {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  isAllDay Boolean   @default(false)
  date     DateTime? @db.Date

  title       String
  description String?
  dueTime     DateTime?
  priority    TodoPriority @default(MEDIUM)
  category    TodoCategory @default(STUDY)
  duration    Int?
  status      TodoStatus   @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, dueTime])
  @@index([userId, date, isAllDay])
  @@index([userId, status])
  @@index([userId, priority, dueTime])
  @@index([userId, priority, date, isAllDay])
}

model CalendarEvent {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  title     String
  startTime DateTime
  endTime   DateTime

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, startTime, endTime])
}

// --- Central AI Interaction Event Model ---
model AiInteractionEvent {
  id     String @id @default(cuid())
  userId String
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  timestamp DateTime                 @default(now())
  type      AiInteractionContentType

  // Foreign keys to specific content types
  userInputMessageId     String? @unique
  modelResponseMessageId String? @unique
  functionCallRequestId  String? @unique
  functionCallResultId   String? @unique

  // Relations to specific content models
  userInputMessage     UserInputMessage?      @relation("UserInputMessageToEvent", fields: [userInputMessageId], references: [id], onDelete: Cascade)
  modelResponseMessage ModelResponseMessage?  @relation("ModelResponseMessageToEvent", fields: [modelResponseMessageId], references: [id], onDelete: Cascade)
  functionCallRequest  AiFunctionCallRequest? @relation("FunctionCallRequestToEvent", fields: [functionCallRequestId], references: [id], onDelete: Cascade)
  functionCallResult   AiFunctionCallResult?  @relation("FunctionCallResultToEvent", fields: [functionCallResultId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId, timestamp])
  @@index([userId, timestamp], name: "idx_user_thread_time")
  @@index([type])
}

// --- Specific Content Models for AI Interactions ---

model UserInputMessage {
  id   String @id @default(cuid())
  text String

  event AiInteractionEvent? @relation("UserInputMessageToEvent")
}

model ModelResponseMessage {
  id     String         @id @default(cuid())
  text   String
  rating MessageRating?

  event AiInteractionEvent? @relation("ModelResponseMessageToEvent")
}

model AiFunctionCallRequest {
  id   String @id @default(cuid())
  name String
  args Json

  event AiInteractionEvent? @relation("FunctionCallRequestToEvent")
}

model AiFunctionCallResult {
  id       String @id @default(cuid())
  name     String
  response Json

  event AiInteractionEvent? @relation("FunctionCallResultToEvent")
}
